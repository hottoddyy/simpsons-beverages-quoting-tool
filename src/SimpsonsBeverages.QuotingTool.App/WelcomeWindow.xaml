<Window x:Class="SimpsonsBeverages.QuotingTool.App.WelcomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Simpsons Beverages Quoting Tool"
        Icon="Assets/simpsons-logo.ico"
        Width="480" Height="530"
        MinWidth="480" MinHeight="530"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        FontFamily="Segoe UI"
        Background="#eef4f7"
        Language="en-GB">

    <Window.Resources>

        <!-- ── Button styles ─────────────────────────────────────────── -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"       Value="#052A61"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="FontSize"         Value="14"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="Padding"          Value="28,11"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0a3d8a"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#041e47"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#b0bec5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#052A61"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="28,11"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BorderBrush"     Value="#052A61"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#e6edf8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#d0dcf0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BackBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#8CBECF"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock x:Name="Txt" Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontSize="{TemplateBinding FontSize}"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Txt" Property="Foreground" Value="#052A61"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── List item style ──────────────────────────────────────── -->
        <Style x:Key="RowItem" TargetType="ListBoxItem">
            <Setter Property="Padding"          Value="12,8"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="#cfd8df" BorderThickness="0,0,0,1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#edf3f7"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#d4e8f2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <!-- ════════════════════════════════════════════════════════════ -->
        <!--  WELCOME PANEL                                              -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <Grid x:Name="WelcomePanel">
            <StackPanel VerticalAlignment="Center" Margin="60,0">

                <Image Source="pack://application:,,,/Assets/simpsons-logo-blue.png"
                       Height="110" Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       HorizontalAlignment="Center" Margin="0,0,0,32"/>

                <TextBlock x:Name="GreetingText"
                           FontSize="22" FontWeight="Light" Foreground="#052A61"
                           TextWrapping="Wrap" TextAlignment="Center"
                           HorizontalAlignment="Center" Margin="0,0,0,6"/>

                <TextBlock Text="What would you like to do today?"
                           FontSize="13" Foreground="#64707a"
                           TextAlignment="Center" HorizontalAlignment="Center"
                           Margin="0,0,0,40"/>

                <Button Content="  ✚  Create Quote"
                        Style="{StaticResource PrimaryBtn}"
                        Width="240" Margin="0,0,0,10"
                        Click="CreateQuoteClicked"/>

                <Button Content="  ⌕  Find Quote"
                        Style="{StaticResource SecondaryBtn}"
                        Width="240"
                        Click="FindQuoteClicked"/>

            </StackPanel>

            <TextBlock Text="v1.4.0" FontSize="11" Foreground="#c0cdd5"
                       VerticalAlignment="Bottom" HorizontalAlignment="Right"
                       Margin="0,0,12,8"/>
        </Grid>

        <!-- ════════════════════════════════════════════════════════════ -->
        <!--  CUSTOMER SELECT PANEL                                      -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <Grid x:Name="CustomerPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Button Grid.Row="0" Content="← Back" Style="{StaticResource BackBtn}"
                    HorizontalAlignment="Left" Margin="20,16,0,0"
                    Click="CustomerBackClicked"/>

            <StackPanel Grid.Row="1" Margin="32,10,32,10">
                <TextBlock Text="New Quote" FontSize="20" FontWeight="SemiBold" Foreground="#052A61"/>
                <TextBlock Text="Choose a customer, or type a new name to add them."
                           FontSize="12" Foreground="#64707a" Margin="0,2,0,0"/>
            </StackPanel>

            <!-- Search box with placeholder -->
            <Grid Grid.Row="2" Margin="32,0,32,0">
                <Border BorderBrush="#cfd8df" BorderThickness="1" CornerRadius="4" Background="White">
                    <TextBox x:Name="CustomerSearchBox" FontSize="13" Padding="10,7"
                             BorderThickness="0" Background="Transparent"
                             VerticalContentAlignment="Center"
                             TextChanged="CustomerSearchChanged"
                             KeyDown="CustomerSearchKeyDown"/>
                </Border>
                <TextBlock x:Name="CustomerPlaceholder"
                           Text="Search or type a new customer name…"
                           FontSize="13" Foreground="#b0bec5"
                           Margin="12,8,0,0" IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=CustomerSearchBox}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <!-- Customer list -->
            <ListBox x:Name="CustomerListBox" Grid.Row="3"
                     Margin="32,4,32,0"
                     BorderThickness="1" BorderBrush="#cfd8df"
                     Background="White"
                     ItemContainerStyle="{StaticResource RowItem}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     SelectionChanged="CustomerSelectionChanged"
                     MouseDoubleClick="CustomerListDoubleClicked">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontSize="13" Foreground="#172026" TextWrapping="NoWrap"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Button x:Name="ContinueButton" Grid.Row="4"
                    Content="Continue →"
                    Style="{StaticResource PrimaryBtn}"
                    Width="148" HorizontalAlignment="Right"
                    Margin="0,10,32,18"
                    IsEnabled="False"
                    Click="ContinueClicked"/>
        </Grid>

        <!-- ════════════════════════════════════════════════════════════ -->
        <!--  UPDATE BANNER  (overlays all panels at the bottom)        -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <Border x:Name="UpdateBanner" VerticalAlignment="Bottom"
                Visibility="Collapsed"
                Background="#fff8e1" BorderBrush="#f59e0b" BorderThickness="0,1,0,0"
                Padding="16,8">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="UpdateText" FontSize="12" Foreground="#78350f"
                               VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <Button x:Name="UpdateInstallBtn" Content="Install now"
                            Margin="12,0,0,0" Padding="12,5"
                            Style="{StaticResource PrimaryBtn}" FontSize="12"
                            Click="UpdateInstallClicked"/>
                </StackPanel>
                <Button Content="✕" HorizontalAlignment="Right"
                        Style="{StaticResource BackBtn}" VerticalAlignment="Center"
                        Click="UpdateDismissClicked"/>
            </Grid>
        </Border>

        <!-- ════════════════════════════════════════════════════════════ -->
        <!--  FIND QUOTE PANEL                                           -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <Grid x:Name="FindPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Button Grid.Row="0" Content="← Back" Style="{StaticResource BackBtn}"
                    HorizontalAlignment="Left" Margin="20,16,0,0"
                    Click="FindBackClicked"/>

            <StackPanel Grid.Row="1" Margin="32,10,32,10">
                <TextBlock Text="Find Quote" FontSize="20" FontWeight="SemiBold" Foreground="#052A61"/>
                <TextBlock Text="Search by customer name, quote number, or product code."
                           FontSize="12" Foreground="#64707a" Margin="0,2,0,0"/>
            </StackPanel>

            <!-- Search box with placeholder -->
            <Grid Grid.Row="2" Margin="32,0,32,0">
                <Border BorderBrush="#cfd8df" BorderThickness="1" CornerRadius="4" Background="White">
                    <TextBox x:Name="FindSearchBox" FontSize="13" Padding="10,7"
                             BorderThickness="0" Background="Transparent"
                             VerticalContentAlignment="Center"
                             TextChanged="FindSearchChanged"/>
                </Border>
                <TextBlock x:Name="FindPlaceholder"
                           Text="Customer name, quote number, or product code…"
                           FontSize="13" Foreground="#b0bec5"
                           Margin="12,8,0,0" IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=FindSearchBox}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <!-- Results list -->
            <ListBox x:Name="FindListBox" Grid.Row="3"
                     Margin="32,4,32,0"
                     BorderThickness="1" BorderBrush="#cfd8df"
                     Background="White"
                     ItemContainerStyle="{StaticResource RowItem}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     SelectionChanged="FindSelectionChanged"
                     MouseDoubleClick="FindListDoubleClicked">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#172026">
                                <Run Text="{Binding QuoteNumber, Mode=OneWay}"/>
                                <Run Text=" · "/>
                                <Run Text="{Binding Customer, Mode=OneWay}"/>
                            </TextBlock>
                            <TextBlock Text="{Binding ModifiedAt, Mode=OneWay}"
                                       FontSize="11" Foreground="#64707a" Margin="0,1,0,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Button x:Name="OpenQuoteButton" Grid.Row="4"
                    Content="Open Quote →"
                    Style="{StaticResource PrimaryBtn}"
                    Width="160" HorizontalAlignment="Right"
                    Margin="0,10,32,18"
                    IsEnabled="False"
                    Click="OpenQuoteClicked"/>
        </Grid>
    </Grid>
</Window>
