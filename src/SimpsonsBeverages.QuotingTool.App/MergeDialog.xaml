<Window x:Class="SimpsonsBeverages.QuotingTool.App.MergeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Merge customers"
        Icon="Assets/simpsons-logo.ico"
        Width="380" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="Segoe UI"
        Background="#eef4f7"
        ShowInTaskbar="False">
    <StackPanel Margin="28,24">
        <TextBlock Text="Which name should survive the merge?"
                   FontSize="13" FontWeight="SemiBold" Foreground="#052A61" Margin="0,0,0,16"/>

        <RadioButton x:Name="RadioA" FontSize="13" Foreground="#172026"
                     Margin="0,0,0,8" IsChecked="True"/>
        <RadioButton x:Name="RadioB" FontSize="13" Foreground="#172026"
                     Margin="0,0,0,20"/>

        <TextBlock FontSize="12" Foreground="#64707a" TextWrapping="Wrap" Margin="0,0,0,20">
            All quotes from the deleted customer will be reassigned to the surviving name.
        </TextBlock>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="80" Height="34" Margin="0,0,10,0"
                    Background="Transparent" BorderBrush="#cfd8df" BorderThickness="1.5"
                    FontSize="13" Cursor="Hand" Click="CancelClicked"/>
            <Button Content="Merge" Width="90" Height="34"
                    Background="#052A61" Foreground="White" BorderThickness="0"
                    FontSize="13" FontWeight="SemiBold" Cursor="Hand" Click="MergeClicked"/>
        </StackPanel>
    </StackPanel>
</Window>
