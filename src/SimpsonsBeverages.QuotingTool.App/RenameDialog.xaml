<Window x:Class="SimpsonsBeverages.QuotingTool.App.RenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rename customer"
        Icon="Assets/simpsons-logo.ico"
        Width="360" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="Segoe UI"
        Background="#eef4f7"
        ShowInTaskbar="False">
    <StackPanel Margin="28,24">
        <TextBlock x:Name="PromptText" FontSize="13" Foreground="#052A61"
                   FontWeight="SemiBold" Margin="0,0,0,10"/>
        <Border BorderBrush="#cfd8df" BorderThickness="1" CornerRadius="4" Background="White" Margin="0,0,0,18">
            <TextBox x:Name="NameBox" FontSize="13" Padding="10,7"
                     BorderThickness="0" Background="Transparent"
                     VerticalContentAlignment="Center"
                     KeyDown="NameBoxKeyDown"/>
        </Border>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="80" Height="34" Margin="0,0,10,0"
                    Background="Transparent" BorderBrush="#cfd8df" BorderThickness="1.5"
                    FontSize="13" Cursor="Hand" Click="CancelClicked"/>
            <Button Content="Rename" Width="90" Height="34"
                    Background="#052A61" Foreground="White" BorderThickness="0"
                    FontSize="13" FontWeight="SemiBold" Cursor="Hand" Click="OkClicked"/>
        </StackPanel>
    </StackPanel>
</Window>
