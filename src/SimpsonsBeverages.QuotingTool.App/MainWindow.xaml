<Window x:Class="SimpsonsBeverages.QuotingTool.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Simpsons Beverages Quoting Tool"
        Height="790"
        Width="1320"
        MinHeight="700"
        MinWidth="1120"
        WindowState="Maximized"
        FontFamily="Verdana"
        Language="en-GB"
        Background="#eef4f7">
    <Window.Resources>
        <SolidColorBrush x:Key="InkBrush" Color="#172026" />
        <SolidColorBrush x:Key="MutedBrush" Color="#64707a" />
        <SolidColorBrush x:Key="NavyBrush" Color="#052A61" />
        <SolidColorBrush x:Key="PaleBlueBrush" Color="#8CBECF" />
        <SolidColorBrush x:Key="PanelBrush" Color="#ffffff" />
        <SolidColorBrush x:Key="LineBrush" Color="#cfd8df" />
        <SolidColorBrush x:Key="SoftBrush" Color="#f7fbfc" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#30404a" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="9,5" />
            <Setter Property="BorderBrush" Value="#b9c6cf" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="White" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Padding" Value="14,4" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="{StaticResource NavyBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource NavyBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#dbe5ea" />
            <Setter Property="Foreground" Value="#1d3038" />
            <Setter Property="BorderBrush" Value="#c7d5dc" />
        </Style>

        <Style x:Key="PositiveButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#1f7a61" />
            <Setter Property="BorderBrush" Value="#17624e" />
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#8a4b4b" />
            <Setter Property="BorderBrush" Value="#6f3c3c" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#e3ebef" />
            <Setter Property="VerticalGridLinesBrush" Value="#edf3f6" />
            <Setter Property="RowHeight" Value="32" />
            <Setter Property="ColumnHeaderHeight" Value="34" />
            <Setter Property="AlternatingRowBackground" Value="#f2f2f2" />
            <Setter Property="RowBackground" Value="#ffffff" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="SelectionMode" Value="Extended" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource NavyBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="BorderBrush" Value="#12386e" />
            <Setter Property="BorderThickness" Value="0,0,1,0" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="BorderBrush" Value="#edf3f6" />
            <Setter Property="BorderThickness" Value="0,0,1,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="QuoteGridCellPreviewMouseLeftButtonDown" />
            <EventSetter Event="PreviewMouseMove" Handler="QuoteGridCellPreviewMouseMove" />
            <EventSetter Event="PreviewMouseLeftButtonUp" Handler="QuoteGridCellPreviewMouseLeftButtonUp" />
        </Style>

        <Style x:Key="RowSelectCheckBox" TargetType="CheckBox">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="ToolTip" Value="Mark row for deletion" />
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="FontWeight" Value="Bold" />
                    <Setter Property="Background" Value="{StaticResource PaleBlueBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource NavyBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1" Padding="24,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="260" />
                </Grid.ColumnDefinitions>

                <Image Source="Assets/simpsons-logo-blue.png" Width="116" Stretch="Uniform" VerticalAlignment="Center" />

                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="Quoting Tool" FontSize="25" FontWeight="Bold" Foreground="{StaticResource NavyBrush}" />
                    <TextBlock Text="Build customer quotes from accurate costing inputs" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0" />
                </StackPanel>

                <Border x:Name="GpIndicator" Grid.Column="3" Height="64" CornerRadius="4"
                        Background="#d8dee6" BorderBrush="{StaticResource LineBrush}" BorderThickness="1">
                    <Grid Margin="14,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Average GP" Foreground="#394b59" FontWeight="Bold" />
                            <TextBlock Text="Calculated from valid lines" Foreground="#596775" FontSize="10" Margin="0,3,0,0" />
                        </StackPanel>
                        <TextBlock Grid.Column="1" x:Name="AverageGpDisplay" Text="-" VerticalAlignment="Center"
                                   FontSize="20" FontWeight="Bold" Foreground="#172026" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="24,20,24,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="210" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Customer" Style="{StaticResource FieldLabel}" />
                        <TextBox x:Name="CustomerBox" TextChanged="HeaderInputChanged" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                        <Button Content="Add line" Click="AddLineClicked" />
                        <Button Content="Remove selected" Click="RemoveSelectedClicked" Style="{StaticResource SecondaryButton}" MinWidth="138" />
                        <Button Content="Recalculate" Click="RecalculateClicked" />
                        <Button Content="Import Excel" Click="ImportLegacyExcelClicked" Style="{StaticResource SecondaryButton}" MinWidth="112" />
                        <Button Content="Import Tab" Click="ImportLegacySheetClicked" Style="{StaticResource SecondaryButton}" MinWidth="104" />
                        <Button Content="Export Excel" Click="ExportLegacyExcelClicked" Style="{StaticResource SecondaryButton}" MinWidth="112" />
                        <Button Content="Export PDF" Click="ExportPdfClicked" Style="{StaticResource PositiveButton}" />
                        <Button Content="Reset" Click="ResetClicked" Style="{StaticResource DangerButton}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="14,10,14,8">
                        <TextBlock Text="Input costs and target GP; calculated fields update automatically"
                                   DockPanel.Dock="Right" Foreground="{StaticResource MutedBrush}" FontSize="11"
                                   HorizontalAlignment="Right" Margin="24,2,0,0" />
                        <TextBlock Text="Quote Lines" FontSize="15" FontWeight="Bold" Foreground="{StaticResource NavyBrush}" />
                    </DockPanel>

                    <DataGrid Grid.Row="1" x:Name="QuoteGrid"
                              RowHeaderWidth="28"
                              BeginningEdit="QuoteGridBeginningEdit"
                              CellEditEnding="QuoteGridCellEditEnding"
                              CurrentCellChanged="QuoteGridCurrentCellChanged"
                              PreviewKeyDown="QuoteGridPreviewKeyDown"
                              ItemsSource="{Binding Lines}">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="" Width="42">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox Style="{StaticResource RowSelectCheckBox}"
                                                  IsChecked="{Binding IsMarkedForDelete, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridComboBoxColumn x:Name="FormatColumn" Header="Format" SelectedItemBinding="{Binding FormatName, UpdateSourceTrigger=PropertyChanged}" Width="140">
                                <DataGridComboBoxColumn.EditingElementStyle>
                                    <Style TargetType="ComboBox">
                                        <EventSetter Event="Loaded" Handler="FormatComboBoxLoaded" />
                                    </Style>
                                </DataGridComboBoxColumn.EditingElementStyle>
                            </DataGridComboBoxColumn>
                            <DataGridTextColumn x:Name="CodeColumn" Header="Code" Binding="{Binding Code, UpdateSourceTrigger=PropertyChanged}" Width="105" />
                            <DataGridTextColumn x:Name="DescriptionColumn" Header="Description" Binding="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Width="430" />
                            <DataGridTextColumn x:Name="DilutionColumn" Header="Dilution" Binding="{Binding DilutionParts, UpdateSourceTrigger=PropertyChanged}" Width="110" />
                            <DataGridTextColumn x:Name="TargetGpColumn" Header="Target GP %" Binding="{Binding TargetGpPercent, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:N2}}" Width="130" />
                            <DataGridTextColumn x:Name="PackCostColumn" Header="Pack cost" Binding="{Binding PackCost, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:N4}}" Width="120" />
                            <DataGridTextColumn x:Name="PricePerUnitColumn" Header="Quote GBP/unit" Binding="{Binding PricePerUnitText, UpdateSourceTrigger=PropertyChanged}" Width="145" />
                            <DataGridTextColumn x:Name="UsagePriceColumn" Header="Cost in use (£/RTD L)" Binding="{Binding UsagePriceDisplay}" IsReadOnly="True" Width="180" />
                            <DataGridTemplateColumn x:Name="ServeCostColumn" Header="Serve cost" Width="170">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding ServeCostSummary}"
                                                Click="ServeCostSettingsClicked"
                                                Style="{StaticResource SecondaryButton}"
                                                MinWidth="0"
                                                Height="26"
                                                Margin="4,0"
                                                Padding="8,0"
                                                ToolTip="Set optional ml cost" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn x:Name="RecipeCostColumn" Header="Recipe GBP/1000L" Binding="{Binding RecipeCostPer1000L, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:N4}}" Width="160" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Row="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="14" Margin="0,14,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="Customer-facing fields only" DockPanel.Dock="Right" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="18,2,0,0" />
                        <TextBlock Text="Customer Quote Preview" FontSize="15" FontWeight="Bold" Foreground="{StaticResource NavyBrush}" />
                    </DockPanel>
                    <Border Grid.Row="1" Background="{StaticResource SoftBrush}" BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1" Padding="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="245" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Simpsons Beverages" FontWeight="Bold" Foreground="{StaticResource NavyBrush}" FontSize="13" />
                                <TextBlock Text="Customer Quote" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,2,0,10" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Customer" FontWeight="Bold" FontSize="11" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="PreviewCustomerText" Text="-" FontSize="11" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Date" FontWeight="Bold" FontSize="11" Margin="0,6,0,0" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="PreviewDateText" Text="-" FontSize="11" Margin="0,6,0,0" />
                                </Grid>

                                <TextBlock Text="Valid for 1 week unless otherwise confirmed."
                                           TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" FontSize="10" Margin="0,14,8,0" />
                            </StackPanel>

                            <DataGrid Grid.Column="2"
                                      ItemsSource="{Binding PreviewLines}"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      RowHeaderWidth="0"
                                      RowHeight="28"
                                      ColumnHeaderHeight="28"
                                      CanUserSortColumns="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="CODE" Binding="{Binding Code}" Width="110" />
                                    <DataGridTextColumn Header="DESCRIPTION" Binding="{Binding Description}" Width="*" />
                                    <DataGridTextColumn Header="UNIT" Binding="{Binding Unit}" Width="90" />
                                    <DataGridTextColumn Header="GBP/UNIT" Binding="{Binding PricePerUnit}" Width="100" />
                                    <DataGridTextColumn x:Name="PreviewUsagePriceColumn" Header="£/RTD L" Binding="{Binding CostInUse}" Width="150" />
                                    <DataGridTextColumn x:Name="PreviewServeCostColumn" Header="SERVE COST" Binding="{Binding ServeCost}" Width="105" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#f9fbfc" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0" Padding="24,10">
            <TextBlock x:Name="StatusText" Text="Ready" Foreground="{StaticResource MutedBrush}" />
        </Border>
    </Grid>
</Window>
