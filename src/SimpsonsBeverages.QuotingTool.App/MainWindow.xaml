<Window x:Class="SimpsonsBeverages.QuotingTool.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Simpsons Beverages Quoting Tool"
        Height="820" Width="1340"
        MinHeight="700" MinWidth="1140"
        WindowState="Maximized"
        FontFamily="Segoe UI"
        Language="en-GB"
        Background="{DynamicResource AppBg}"
        PreviewKeyDown="WindowPreviewKeyDown">

    <Window.Resources>
        <!-- ── Theme brushes (mutated at runtime for dark mode) ── -->
        <SolidColorBrush x:Key="AppBg"        Color="#eef4f7" />
        <SolidColorBrush x:Key="HeaderBg"     Color="#ffffff" />
        <SolidColorBrush x:Key="ToolbarBrush" Color="#f2f7fa" />
        <SolidColorBrush x:Key="PanelBrush"   Color="#ffffff" />
        <SolidColorBrush x:Key="SoftBrush"    Color="#f7fbfc" />
        <SolidColorBrush x:Key="LineBrush"    Color="#cfd8df" />
        <SolidColorBrush x:Key="InkBrush"     Color="#172026" />
        <SolidColorBrush x:Key="MutedBrush"   Color="#64707a" />
        <SolidColorBrush x:Key="RowHoverBrush"  Color="#edf3f7" />
        <SolidColorBrush x:Key="RowSelectBrush" Color="#d4e8f2" />
        <SolidColorBrush x:Key="TextBoxBg"    Color="#ffffff" />
        <SolidColorBrush x:Key="TextBoxBorder" Color="#8a9fad" />

        <!-- ── Header theming ── -->
        <SolidColorBrush x:Key="TitleFg"    Color="#052A61" />
        <SolidColorBrush x:Key="GpLabelFg"  Color="#394b59" />
        <SolidColorBrush x:Key="GpSubFg"    Color="#596775" />
        <SolidColorBrush x:Key="GpCardBg"   Color="#d8dee6" />

        <!-- ── Accent (switches in dark mode) ── -->
        <SolidColorBrush x:Key="AccentBrush" Color="#052A61" />
        <SolidColorBrush x:Key="AccentFg"    Color="#ffffff" />

        <!-- ── Fixed colours ── -->
        <SolidColorBrush x:Key="NavyBrush"     Color="#052A61" />
        <SolidColorBrush x:Key="PaleBlueBrush" Color="#8CBECF" />

        <!-- ── Base text ── -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
            <Setter Property="FontSize"   Value="12" />
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource MutedBrush}" />
            <Setter Property="FontSize"   Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin"     Value="0,0,0,4" />
        </Style>

        <!-- ── TextBox ── -->
        <Style TargetType="TextBox">
            <Setter Property="Height"                   Value="32" />
            <Setter Property="Padding"                  Value="9,0" />
            <Setter Property="BorderBrush"              Value="{DynamicResource TextBoxBorder}" />
            <Setter Property="BorderThickness"          Value="1.5" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background"               Value="{DynamicResource TextBoxBg}" />
            <Setter Property="Foreground"               Value="{DynamicResource InkBrush}" />
            <Setter Property="FontSize"                 Value="12" />
        </Style>

        <!-- ── Button ── -->
        <Style TargetType="Button">
            <Setter Property="Height"          Value="30" />
            <Setter Property="Padding"         Value="13,0" />
            <Setter Property="Margin"          Value="0,0,4,0" />
            <Setter Property="Background"      Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground"      Value="{DynamicResource AccentFg}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize"        Value="12" />
            <Setter Property="FontWeight"      Value="SemiBold" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.80" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.60" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.38" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background"      Value="{DynamicResource RowHoverBrush}" />
            <Setter Property="Foreground"      Value="{DynamicResource MutedBrush}" />
            <Setter Property="BorderBrush"     Value="{DynamicResource MutedBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="PositiveButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#1f7a61" />
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#8a4b4b" />
        </Style>

        <!-- Dark mode toggle button -->
        <Style x:Key="IconButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush"     Value="{DynamicResource LineBrush}" />
            <Setter Property="Foreground"      Value="{DynamicResource MutedBrush}" />
            <Setter Property="Width"           Value="34" />
            <Setter Property="Height"          Value="34" />
            <Setter Property="Padding"         Value="0" />
            <Setter Property="FontSize"        Value="15" />
            <Setter Property="Margin"          Value="0,0,10,0" />
        </Style>

        <!-- ── Toolbar separator ── -->
        <Style x:Key="ToolSep" TargetType="Separator">
            <Setter Property="Background"        Value="{DynamicResource LineBrush}" />
            <Setter Property="Width"             Value="1" />
            <Setter Property="Margin"            Value="6,2" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
        </Style>

        <!-- ── Cell text (vertical centering) ── -->
        <Style x:Key="CellText" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin"            Value="8,0" />
            <Setter Property="TextTrimming"      Value="CharacterEllipsis" />
        </Style>

        <!-- ── DataGrid ── -->
        <Style TargetType="DataGrid">
            <Setter Property="Background"               Value="{DynamicResource PanelBrush}" />
            <Setter Property="Foreground"               Value="{DynamicResource InkBrush}" />
            <Setter Property="BorderThickness"          Value="0" />
            <Setter Property="GridLinesVisibility"      Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource LineBrush}" />
            <Setter Property="RowHeight"                Value="34" />
            <Setter Property="ColumnHeaderHeight"       Value="36" />
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource SoftBrush}" />
            <Setter Property="RowBackground"            Value="{DynamicResource PanelBrush}" />
            <Setter Property="CanUserAddRows"           Value="False" />
            <Setter Property="CanUserDeleteRows"        Value="False" />
            <Setter Property="AutoGenerateColumns"      Value="False" />
            <Setter Property="SelectionMode"            Value="Extended" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource RowHoverBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource RowSelectBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground"      Value="{DynamicResource AccentFg}" />
            <Setter Property="FontWeight"      Value="SemiBold" />
            <Setter Property="FontSize"        Value="11" />
            <Setter Property="Padding"         Value="8,0" />
            <Setter Property="BorderBrush"     Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="0,0,1,0" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding"                  Value="0" />
            <Setter Property="BorderThickness"          Value="0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="QuoteGridCellPreviewMouseLeftButtonDown" />
            <EventSetter Event="PreviewMouseMove"           Handler="QuoteGridCellPreviewMouseMove" />
            <EventSetter Event="PreviewMouseLeftButtonUp"   Handler="QuoteGridCellPreviewMouseLeftButtonUp" />
        </Style>

        <!-- Tiny up/down reorder buttons in the line number column -->
        <Style x:Key="MicroButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground"      Value="{DynamicResource MutedBrush}" />
            <Setter Property="FontSize"        Value="8" />
            <Setter Property="Width"           Value="14" />
            <Setter Property="Height"          Value="12" />
            <Setter Property="Padding"         Value="0" />
            <Setter Property="Margin"          Value="0" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource RowHoverBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RowSelectCheckBox" TargetType="CheckBox">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment"   Value="Center" />
            <Setter Property="ToolTip"             Value="Mark row for deletion" />
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background"  Value="{StaticResource PaleBlueBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource NavyBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="5"    />   <!-- navy accent strip -->
            <RowDefinition Height="Auto" />   <!-- header -->
            <RowDefinition Height="Auto" />   <!-- toolbar -->
            <RowDefinition Height="*"    />   <!-- content -->
            <RowDefinition Height="Auto" />   <!-- status bar -->
        </Grid.RowDefinitions>

        <!-- ACCENT STRIP -->
        <Border Grid.Row="0" Background="{DynamicResource AccentBrush}" />

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="1"
                x:Name="HeaderBorder"
                Background="{DynamicResource HeaderBg}"
                BorderBrush="{DynamicResource LineBrush}"
                BorderThickness="0,0,0,1"
                Padding="22,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="18"   />
                    <ColumnDefinition Width="*"    />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Image x:Name="LogoColor"
                       Source="Assets/simpsons-logo-blue.png"
                       Width="112" Stretch="Uniform" VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       SnapsToDevicePixels="True" />
                <Image x:Name="LogoWhite"
                       Source="Assets/simpsons-logo-white.png"
                       Width="112" Stretch="Uniform" VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       SnapsToDevicePixels="True"
                       Visibility="Collapsed" />

                <TextBlock Grid.Column="2"
                           Text="Quoting Tool"
                           FontSize="26" FontWeight="Bold"
                           Foreground="{DynamicResource TitleFg}"
                           VerticalAlignment="Center" />

                <!-- Dark mode toggle -->
                <Button Grid.Column="3"
                        x:Name="DarkModeButton"
                        Content="☾"
                        Click="DarkModeToggleClicked"
                        Style="{StaticResource IconButton}"
                        ToolTip="Toggle dark mode"
                        VerticalAlignment="Center" />

                <!-- GP indicator -->
                <Border x:Name="GpIndicator"
                        Grid.Column="4"
                        Width="230" Height="64"
                        CornerRadius="4"
                        Background="{DynamicResource GpCardBg}"
                        BorderBrush="{DynamicResource LineBrush}"
                        BorderThickness="1">
                    <Grid Margin="16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"    />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Average GP"
                                       Foreground="{DynamicResource GpLabelFg}"
                                       FontWeight="SemiBold" FontSize="12" />
                            <TextBlock x:Name="GpSubtitle"
                                       Text="Add lines to calculate"
                                       Foreground="{DynamicResource GpSubFg}"
                                       FontSize="10" Margin="0,3,0,0" />
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   x:Name="AverageGpDisplay"
                                   Text="—"
                                   VerticalAlignment="Center"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="#9aaab5" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ═══ TOOLBAR ═══ -->
        <Border Grid.Row="2"
                Background="{DynamicResource ToolbarBrush}"
                BorderBrush="{DynamicResource LineBrush}"
                BorderThickness="0,0,0,1"
                Padding="22,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10"   />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Customer + Quote no. -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="CUSTOMER" Style="{StaticResource FieldLabel}" />
                        <TextBox x:Name="CustomerBox" Width="280" TextChanged="HeaderInputChanged" />
                    </StackPanel>
                    <StackPanel Margin="20,0,0,0">
                        <TextBlock Text="QUOTE NO." Style="{StaticResource FieldLabel}" />
                        <Border Background="{DynamicResource TextBoxBg}"
                                BorderBrush="{DynamicResource TextBoxBorder}"
                                BorderThickness="1.5"
                                CornerRadius="2"
                                Height="32"
                                MinWidth="170"
                                Padding="10,0">
                            <TextBlock x:Name="QuoteNumberDisplay"
                                       Text="Not saved"
                                       FontSize="12" FontStyle="Italic"
                                       Foreground="{DynamicResource MutedBrush}"
                                       VerticalAlignment="Center" />
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- Action buttons -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center" Height="30">
                    <Button Content="Add Line" Click="AddLineClicked" />
                    <Button Content="▲" Click="MoveLineUpClicked"   Style="{StaticResource SecondaryButton}" ToolTip="Move selected line up"   Width="30" />
                    <Button Content="▼" Click="MoveLineDownClicked" Style="{StaticResource SecondaryButton}" ToolTip="Move selected line down" Width="30" />
                    <Button Content="Remove"   Click="RemoveSelectedClicked" Style="{StaticResource SecondaryButton}" />

                    <Separator Style="{StaticResource ToolSep}" />

                    <Button Content="Import Excel" Click="ImportLegacyExcelClicked" Style="{StaticResource SecondaryButton}" />
                    <Button Content="Import Tab"   Click="ImportLegacySheetClicked" Style="{StaticResource SecondaryButton}" />

                    <Separator Style="{StaticResource ToolSep}" />

                    <Button Content="Export Excel" Click="ExportLegacyExcelClicked" Style="{StaticResource SecondaryButton}" />
                    <Button Content="Save Quote"   Click="SaveQuoteClicked"         Style="{StaticResource PositiveButton}" />
                    <Button Content="Open Quote"   Click="OpenQuoteClicked"         Style="{StaticResource SecondaryButton}" />
                    <Button Content="Export PDF"   Click="ExportPdfClicked"         Style="{StaticResource PositiveButton}" />

                    <Separator Style="{StaticResource ToolSep}" />

                    <Button Content="Reset" Click="ResetClicked" Style="{StaticResource DangerButton}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ CONTENT ═══ -->
        <Grid Grid.Row="3" Margin="22,16,22,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"   />
                <RowDefinition Height="196" />
            </Grid.RowDefinitions>

            <!-- Quote lines grid -->
            <Border Grid.Row="0"
                    Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource LineBrush}"
                    BorderThickness="1" CornerRadius="4"
                    Margin="0,0,0,12"
                    UseLayoutRounding="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*"    />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="16,11,16,9">
                        <TextBlock Text="Input costs and target GP · calculated fields update automatically"
                                   DockPanel.Dock="Right"
                                   Foreground="{DynamicResource MutedBrush}"
                                   FontSize="11" VerticalAlignment="Center"
                                   Margin="24,0,0,0" />
                        <TextBlock Text="Quote Lines"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TitleFg}" />
                    </DockPanel>

                    <DataGrid Grid.Row="1"
                              x:Name="QuoteGrid"
                              RowHeaderWidth="0"
                              BeginningEdit="QuoteGridBeginningEdit"
                              CellEditEnding="QuoteGridCellEditEnding"
                              CurrentCellChanged="QuoteGridCurrentCellChanged"
                              PreviewKeyDown="QuoteGridPreviewKeyDown"
                              ItemsSource="{Binding Lines}">
                        <!-- Override global TextBox style inside grid cells:
                             remove fixed Height so the box stretches to fill the
                             row (prevents text jumping up on edit), and hook
                             GotFocus for select-all so typing always overwrites. -->
                        <DataGrid.Resources>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Setter Property="Height"            Value="Auto" />
                                <Setter Property="VerticalAlignment" Value="Stretch" />
                                <Setter Property="Padding"           Value="3,0" />
                                <EventSetter Event="GotFocus" Handler="QuoteGridTextBoxGotFocus" />
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <!-- Line number (read-only; reorder via toolbar ▲▼ buttons) -->
                            <DataGridTemplateColumn Header="#" Width="36" CanUserSort="False" CanUserReorder="False" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding LineNumber}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource MutedBrush}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <!-- Delete checkbox -->
                            <DataGridTemplateColumn Header="" Width="36" CanUserSort="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox Style="{StaticResource RowSelectCheckBox}"
                                                  IsChecked="{Binding IsMarkedForDelete, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn x:Name="FormatColumn" Header="Format" Width="140" SortMemberPath="FormatName">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FormatName}" Style="{StaticResource CellText}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedItem="{Binding FormatName, UpdateSourceTrigger=PropertyChanged}"
                                                  VerticalContentAlignment="Center"
                                                  Loaded="FormatComboBoxLoaded" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn x:Name="CodeColumn"        Header="Code"                  Binding="{Binding Code,               UpdateSourceTrigger=PropertyChanged}" Width="105"  ElementStyle="{StaticResource CellText}" />
                            <DataGridTextColumn x:Name="DescriptionColumn" Header="Description"           Binding="{Binding Description,        UpdateSourceTrigger=PropertyChanged}" Width="430"  ElementStyle="{StaticResource CellText}" />
                            <DataGridTextColumn x:Name="DilutionColumn"    Header="Dilution"              Binding="{Binding DilutionParts,      UpdateSourceTrigger=PropertyChanged}" Width="110"  ElementStyle="{StaticResource CellText}" />
                            <DataGridTextColumn x:Name="TargetGpColumn"    Header="Target GP %"           Binding="{Binding TargetGpPercent,    UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:N2}}" Width="130" ElementStyle="{StaticResource CellText}" />
                            <DataGridTextColumn x:Name="PackCostColumn"    Header="Pack cost"             Binding="{Binding PackCost,           UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:N4}}" Width="120" ElementStyle="{StaticResource CellText}" />
                            <DataGridTextColumn x:Name="PricePerUnitColumn" Header="Quote GBP/unit"       Binding="{Binding PricePerUnitText,   UpdateSourceTrigger=PropertyChanged}" Width="145"  ElementStyle="{StaticResource CellText}" />
                            <DataGridTextColumn x:Name="UsagePriceColumn"  Header="Cost in use (£/RTD L)" Binding="{Binding UsagePriceDisplay}" IsReadOnly="True" Width="180"         ElementStyle="{StaticResource CellText}" />
                            <DataGridTemplateColumn x:Name="ServeCostColumn" Header="Serve cost" Width="170">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding ServeCostSummary}"
                                                Click="ServeCostSettingsClicked"
                                                Style="{StaticResource SecondaryButton}"
                                                MinWidth="0" Height="24"
                                                Margin="4,0" Padding="8,0"
                                                ToolTip="Set optional serve cost" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn x:Name="RecipeCostColumn" Header="Recipe GBP/1000L" Binding="{Binding RecipeCostPer1000L, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:N4}}" Width="160" ElementStyle="{StaticResource CellText}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Customer quote preview -->
            <Border Grid.Row="1"
                    Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource LineBrush}"
                    BorderThickness="1" CornerRadius="4"
                    Padding="14"
                    UseLayoutRounding="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*"    />
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="Customer-facing fields only"
                                   DockPanel.Dock="Right"
                                   Foreground="{DynamicResource MutedBrush}"
                                   FontSize="11" VerticalAlignment="Center"
                                   Margin="18,0,0,0" />
                        <TextBlock Text="Customer Quote Preview"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TitleFg}" />
                    </DockPanel>

                    <Border Grid.Row="1"
                            Background="{DynamicResource SoftBrush}"
                            BorderBrush="{DynamicResource LineBrush}"
                            BorderThickness="1" CornerRadius="3"
                            Padding="14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="16"  />
                                <ColumnDefinition Width="*"   />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Simpsons Beverages"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource TitleFg}"
                                           FontSize="13" />
                                <TextBlock Text="Customer Quote"
                                           Foreground="{DynamicResource MutedBrush}"
                                           FontSize="11" Margin="0,2,0,12" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="68" />
                                        <ColumnDefinition Width="*"  />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Customer" FontWeight="SemiBold" FontSize="11" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="PreviewCustomerText" Text="—" FontSize="11" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Date"     FontWeight="SemiBold" FontSize="11" Margin="0,5,0,0" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="PreviewDateText" Text="—" FontSize="11" Margin="0,5,0,0" />
                                </Grid>
                                <TextBlock Text="Valid for 1 week unless otherwise confirmed."
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource MutedBrush}"
                                           FontSize="10" Margin="0,14,8,0" />
                            </StackPanel>

                            <DataGrid Grid.Column="2"
                                      ItemsSource="{Binding PreviewLines}"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      RowHeaderWidth="0"
                                      RowHeight="26"
                                      ColumnHeaderHeight="28"
                                      CanUserSortColumns="False"
                                      UseLayoutRounding="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="CODE"        Binding="{Binding Code}"         Width="110" ElementStyle="{StaticResource CellText}" />
                                    <DataGridTextColumn Header="DESCRIPTION" Binding="{Binding Description}"  Width="*"   ElementStyle="{StaticResource CellText}" />
                                    <DataGridTextColumn Header="UNIT"        Binding="{Binding Unit}"         Width="90"  ElementStyle="{StaticResource CellText}" />
                                    <DataGridTextColumn Header="GBP/UNIT"    Binding="{Binding PricePerUnit}" Width="100" ElementStyle="{StaticResource CellText}" />
                                    <DataGridTextColumn x:Name="PreviewUsagePriceColumn" Header="£/RTD L"    Binding="{Binding CostInUse}" Width="150" ElementStyle="{StaticResource CellText}" />
                                    <DataGridTextColumn x:Name="PreviewServeCostColumn"  Header="SERVE COST" Binding="{Binding ServeCost}"  Width="105" ElementStyle="{StaticResource CellText}" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ STATUS BAR ═══ -->
        <Border Grid.Row="4"
                Background="{DynamicResource HeaderBg}"
                BorderBrush="{DynamicResource LineBrush}"
                BorderThickness="0,1,0,0"
                Padding="22,7">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse x:Name="StatusDot"
                         Width="7" Height="7"
                         Fill="{DynamicResource MutedBrush}"
                         Margin="0,0,8,0"
                         VerticalAlignment="Center" />
                <TextBlock x:Name="StatusText"
                           Text="Ready"
                           Foreground="{DynamicResource MutedBrush}"
                           FontSize="11"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
